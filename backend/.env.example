PORT=5000
NODE_ENV=development

# Database (SQLite - auto-created at backend/data/ecommerce.db, no configuration needed)
# DB_PATH=./data/ecommerce.db  ← optional override

# JWT
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# Admin account (created automatically on first startup)
ADMIN_EMAIL=admin@techstore-syria.com
ADMIN_PASSWORD=change_this_password

# CORS - URL of the frontend app
FRONTEND_URL=http://localhost:3000
